function syncFromFirebase(onDone) {
  if (!currentKid) { if (onDone) onDone(); return; }
  let pending = 2; // state + acquired
  let called = false;
  function finish() {
    pending--;
    if (pending <= 0 && !called) { called = true; if (onDone) onDone(); }
  }
  // state
  try {
    fbDB.ref("tilawa/" + currentKid + "/state").once("value").then(snap => {
      try {
        const remote = snap.val();
        let local = null;
        try { local = JSON.parse(localStorage.getItem(kidKey("state"))); } catch(e) {}
        if (remote && (!local || (remote.updatedAt||0) > (local.updatedAt||0))) {
          localStorage.setItem(kidKey("state"), JSON.stringify(remote));
        }
        const remoteSura = parseInt(remote && typeof remote.curSuraIdx === "number" ? remote.curSuraIdx : NaN);
        if (!isNaN(remoteSura)) {
          const localSura = parseInt(localStorage.getItem(kidKey("sura")) || "0");
          if (remoteSura !== localSura) localStorage.setItem(kidKey("sura"), remoteSura);
        }
      } catch(e) {}
      finish();
    }).catch(() => { finish(); });
  } catch(e) { finish(); }
  // acquired
  try {
    fbDB.ref("tilawa/" + currentKid + "/acquired").once("value").then(snap => {
      try {
        const remoteAcq = snap.val();
        if (remoteAcq) {
          let localAcq = {};
          try { localAcq = JSON.parse(localStorage.getItem(kidKey("acquired")) || "{}"); } catch {}
          Object.keys(remoteAcq).forEach(k => {
            if (!localAcq[k] || (remoteAcq[k].lastReviewedAt||0) > (localAcq[k].lastReviewedAt||0)) {
              localAcq[k] = remoteAcq[k];
            }
          });
          localStorage.setItem(kidKey("acquired"), JSON.stringify(localAcq));
        }
      } catch {}
      finish();
    }).catch(() => { finish(); });
  } catch {
    finish();
  }
  // Filet de sécurité : si Firebase ne répond pas (offline, etc.), ne pas bloquer indéfiniment
  setTimeout(() => { if (!called) { called = true; if (onDone) onDone(); } }, 4000);
}

function startSession() {

/* ═══════════════════════════════════════════════════════
   SYSTÈME DE RÉVISION ESPACÉE (Spaced Repetition)
   ═══════════════════════════════════════════════════════
   Pour chaque sourate acquise, on stocke :
     tilawa_<kid>_acquired  →  { suraIdx: { learnedAt, lastReviewedAt, reviewCount } }

   Programme :
     +10 jours → 1ère révision
     +20 jours (30j total) → 2ème révision
     puis tous les 30 jours (cyclique, non-cumulatif)

   Si l'enfant revient après >30j sans avoir révisé :
     → toutes les sourates acquises non révisées récemment sont
       dues d'un coup, mais on n'en fait QU'UNE à la fois
     → pas de nouvelles sourates tant que des révisions sont dues
*/

/* ─── Gestion du stockage "acquis" ─── */
function loadAcquired() {
  try { return JSON.parse(localStorage.getItem(kidKey("acquired")) || "{}"); } catch { return {}; }
}
function saveAcquired(a) {
  localStorage.setItem(kidKey("acquired"), JSON.stringify(a));
  try { fbDB.ref("tilawa/" + currentKid + "/acquired").set(a); } catch(e) {}
}

/* Marquer une sourate comme apprise (appelé depuis showDone) */
function markSuraAcquired(suraIdx) {
  const a = loadAcquired();
  if (!a[suraIdx]) {
    a[suraIdx] = { learnedAt: Date.now(), lastReviewedAt: null, reviewCount: 0 };
    saveAcquired(a);
  }
}

/* Marquer une révision comme faite */
function markReviewDone(suraIdx) {
  const a = loadAcquired();
  if (a[suraIdx]) {
    a[suraIdx].lastReviewedAt = Date.now();
    a[suraIdx].reviewCount = (a[suraIdx].reviewCount || 0) + 1;
    saveAcquired(a);
  }
}

/**
 * Retourne la liste des sourates dont la révision est due,
 * une seule entrée par sourate (non-cumulatif).
 * Tri: la plus urgente en premier.
 */
function getDueReviews() {
  const a = loadAcquired();
  const now = Date.now();
  const DAY = 24 * 60 * 60 * 1000;
  const due = [];

  Object.keys(a).forEach(idxStr => {
    const si = parseInt(idxStr);
    const rec = a[si];
    const learnedAt = rec.learnedAt;
    const lastRev   = rec.lastReviewedAt;
    const daysSinceLearned  = (now - learnedAt) / DAY;
    const daysSinceLastRev  = lastRev ? (now - lastRev) / DAY : Infinity;
    const reviewCount = rec.reviewCount || 0;

    let isDue = false;
    let urgency = 0; // plus petit = plus urgent

    if (reviewCount === 0) {
      // 1ère révision : due après 10 jours
      if (daysSinceLearned >= 10) {
        isDue = true;
        urgency = daysSinceLearned - 10; // depuis combien de temps elle est due
      }
    } else if (reviewCount === 1) {
      // 2ème révision : due 20 jours après la 1ère révision (soit ~30j après apprentissage)
      if (daysSinceLastRev >= 20) {
        isDue = true;
        urgency = daysSinceLastRev - 20;
      }
    } else {
      // Révisions cycliques : toutes les 30 jours depuis la dernière révision
      if (daysSinceLastRev >= 30) {
        isDue = true;
        urgency = daysSinceLastRev - 30;
      }
    }

    if (isDue) due.push({ suraIdx: si, urgency });
  });

  // Trier par urgence décroissante (la plus en retard en premier)
  due.sort((a, b) => b.urgency - a.urgency);
  return due;
}

/**
 * Vérifie si une nouvelle session doit commencer par une révision.
 * Retourne true si une révision a été proposée, false sinon.
 */
function checkAndProposeRevision() {
  const due = getDueReviews();
  if (due.length === 0) return false;

  const { suraIdx } = due[0];
  const sura = BANQUE_SOURATES[suraIdx];
  if (!sura) return false;

  const a = loadAcquired();
  const rec = a[suraIdx];
  const now = Date.now();
  const DAY = 24 * 60 * 60 * 1000;
  const daysSinceLearned = Math.floor((now - rec.learnedAt) / DAY);

  const revScreen = G("review-screen");
  G("rev-sura-name").textContent = sura.nom;

  let msg = "";
  if (rec.reviewCount === 0) {
    msg = `مضى على حفظها ${daysSinceLearned} يوماً — حان وقت التثبيت الأول!`;
  } else {
    const daysSinceLastRev = Math.floor((now - rec.lastReviewedAt) / DAY);
    msg = `مضى ${daysSinceLastRev} يوماً على آخر مراجعة.<br>حان وقت المراجعة الدورية!`;
  }

  if (due.length > 1) {
    msg += `<br><small style="color:#BA7517">(${due.length} سورة بحاجة للمراجعة)</small>`;
  }
  G("rev-msg").innerHTML = msg;

  revScreen.style.display = "flex";

  // Stocker quel sura on va réviser
  window._pendingReviewSuraIdx = suraIdx;
  return true;
}

/* ─── Bouton "ابدأ المراجعة" ─── */

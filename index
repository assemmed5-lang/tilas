<script>
const G = id => document.getElementById(id);

/* ── Auto-fit texte : agrandit/réduit la police pour remplir le cadre #screen
   au maximum, dans les deux dimensions (largeur ET hauteur), sans déborder.
   Remplace l'ancien calcul statique par nombre de caractères en vw. ── */
function autoFitWord(el) {
  const wrap = G("screen");
  if (!wrap) return;
  if (!el.textContent && !el.innerText) return;
  const maxW = wrap.clientWidth  - 8;   // petite marge de sécurité
  const maxH = wrap.clientHeight - 8;
  if (maxW <= 0 || maxH <= 0) return;

  // Couper la transition CSS pendant les calculs : sinon chaque changement
  // de fontSize (20 itérations) anime visuellement → effet de "vibration".
  const prevTransition = el.style.transition;
  el.style.transition = "none";

  // IMPORTANT : pour mesurer le vrai débordement, l'élément doit avoir
  // une largeur intrinsèque (pas width:100%), sinon scrollWidth reste
  // toujours égal à la largeur du cadre et ne détecte jamais le dépassement.
  // On le sort aussi du flux normal (position absolute) pendant la mesure
  // pour qu'il ne puisse pas élargir le document et déclencher un resize.
  const prevPosition = el.style.position;
  const prevVisibility = el.style.visibility;
  el.style.position = "absolute";
  el.style.visibility = "hidden";
  el.style.width = "max-content";
  el.style.maxWidth = "none";
  el.style.whiteSpace = "nowrap";
  el.style.lineHeight = "1.05";
  el.style.display = "block";
  el.style.flexShrink = "0";

  let lo = 8, hi = 600; // bornes en px de font-size
  // recherche binaire de la plus grande taille qui rentre dans le cadre
  for (let i = 0; i < 20; i++) {
    const mid = (lo + hi) / 2;
    el.style.fontSize = mid + "px";
    const w = Math.max(el.scrollWidth, el.getBoundingClientRect().width);
    const h = Math.max(el.scrollHeight, el.getBoundingClientRect().height);
    const fits = w <= maxW && h <= maxH;
    if (fits) lo = mid; else hi = mid;
  }
  el.style.fontSize = lo + "px";

  // Remettre le texte dans le flux normal avec la taille calculée.
  el.style.position = prevPosition || "";
  el.style.visibility = prevVisibility || "";
  el.style.width = "100%";
  el.style.maxWidth = "100%";
  el.style.whiteSpace = "normal";

  // Réactiver la transition juste après, au prochain frame, pour que les
  // futurs changements de taille (mot suivant) restent animés en douceur.
  requestAnimationFrame(() => { el.style.transition = prevTransition || ""; });
}

function setWord(text) {
  const el = G("current-word");
  el.style.lineHeight = "1.05";
  el.textContent = text;

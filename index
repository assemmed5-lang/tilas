function tick() {
  if (stopped) { playing = false; return; }
  if (repCur >= repTotal) {
    playing = false;
    G("btn-listen-stop").classList.add("hidden");
    G("rep-state").textContent = "✅ انتهى الاستماع! جاري الانتقال للتسميع...";
    setTimeout(() => {
      if (phase !== "retry_listen") {
        examUpTo = curVerseIdx;
        examSolo = true;
      }
      const oldRepTotal = repTotal;
      const oldRepCur = repCur;
      repTotal = 1; repCur = 5; // forcer vitesse normale pour la lecture finale
      playOnce(() => {
        repTotal = oldRepTotal;
        repCur = oldRepCur;
        G("audio-player").playbackRate = 1.0;
        beginExamPhase();
      });
    }, 1500);
    return;
  }
  const speedLabel = (phase === "listen" && repCur < 5) ? " 🐢 بطيء" : " ⚡ عادي";
  G("rep-state").textContent = "▶ التكرار رقم " + (repCur+1) + " من " + repTotal + speedLabel;
  playOnce(() => {
    if (stopped) return;
    // En phase retry : réécoute simple, pas de correction mot à mot
      afterVersePlay();
    function afterVersePlay() {
    if (stopped) return;
    repCur++;
    G("rep-cur").textContent = repCur;
    const pct = Math.round((repCur / repTotal) * 100);
    G("prog-fill").style.width = pct + "%";
    G("prog-pct").textContent = pct + "%";
    updateBarRep();
    const win = window._activeWindow;
    const segDur = win ? Math.max((win.end - win.start) * 1000, 600) : 600;
    const rate = (phase === "listen") ? G("audio-player").playbackRate : 1.0;
    const pauseDur = (segDur / rate) * 1.5;

    const SRBrowser = window.SpeechRecognition || window.webkitSpeechRecognition;
    // Annuler le cycle précédent proprement avant d'en démarrer un nouveau
    if (window._pauseTO) { clearTimeout(window._pauseTO); window._pauseTO = null; }
    window._pauseEnded = true;
    if (window._pauseRecog) { try { window._pauseRecog.stop(); } catch(e){} window._pauseRecog = null; }
    window._pauseEnded = false;
    window._pauseSilencePending = false;
    G("transcript").textContent = "";
    G("transcript").style.display = "none";

    if ((phase === "listen" || phase === "retry_listen") && SRBrowser) {
      const expVi = phase === "retry_listen" ? (retryMissing[0] ?? curVerseIdx) : curVerseIdx;
      const expW = verses[expVi] ? verses[expVi].split(/\s+/).filter(Boolean).map(norm) : [];
      let heard = ""; let gotSpeech = false;
      // accumFinal persiste across les redémarrages du micro (silences) —
      // c'est l'équivalent local de finalTx : ne JAMAIS la réinitialiser
      // lors d'un redémarrage, sinon tout ce qui a été dit avant le dernier
      // silence est perdu (bug historique de l'écran d'examen, désormais
      // corrigé aussi ici).
      let accumFinal = "";
      const _pauseStart = Date.now();
      window._pauseEnded = false;

     function _evalPauseFinal() {
        const displayedTxt = (G("transcript").textContent || "").trim();
        if (!displayedTxt || displayedTxt === "...") {
          document.body.style.background = "var(--bg)";
          return false;
        }
        const hn = norm(displayedTxt);
        document.body.style.background = "var(--bg)";
        // Toujours afficher le verset complet avec coloration (blanc=juste, rouge=raté)
        showVerseWithMisses([expVi], hn);
        return true;
      }

      function _startPR() {
        const pr = new SRBrowser();
        pr.lang = "ar-SA"; pr.continuous = true; pr.interimResults = true;
        pr.onresult = e => {
          let im="";
          for(let i=e.resultIndex;i<e.results.length;i++){if(e.results[i].isFinal)accumFinal+=e.results[i][0].transcript+" ";else im+=e.results[i][0].transcript;}
          const txt=(accumFinal+im).trim();
          if(txt.length >= heard.length){heard=txt;gotSpeech=true;}
          const mot=heard.split(/\s+/).filter(Boolean).slice(-1)[0];
          if(mot){setWord(mot);G("transcript").textContent=heard;G("transcript").style.display="block";}
        };
        pr.onend = () => {
          if(!window._pauseRecog || window._pauseEnded) return;
          // CRITIQUE : avant de redémarrer, on fige accumFinal sur le texte
          // affiché le plus complet (heard), pour ne jamais perdre les mots
          // "interim" qui n'avaient pas encore été marqués isFinal.
          if (heard.trim().length >= accumFinal.trim().length) {
            accumFinal = heard.trim() + " ";
          }
          // Toujours redémarrer le moteur tant que la pause globale n'est pas finie —
          // webkitSpeechRecognition s'arrête seul après un court silence, ce n'est PAS
          // la fin de la pause de 3s, juste la fin d'un cycle d'écoute interne.
          setTimeout(()=>{
            if (window._pauseEnded || !window._pauseRecog) return;
            try{
              const r=new SRBrowser(); r.lang="ar-SA"; r.continuous=true; r.interimResults=true;
              r.onresult=pr.onresult; r.onend=pr.onend; window._pauseRecog=r; r.start();
            }catch(e){}
          },50);
        };
        window._pauseRecog = pr;
        try{pr.start();}catch(e){}
      }
      _startPR();
      window._pauseEvalFinal = _evalPauseFinal;
    }

    window._pauseTO = setTimeout(()=>{
      window._pauseTO = null;
      window._pauseEnded = true;
      const hadText = window._pauseEvalFinal ? window._pauseEvalFinal() : true;
      if(window._pauseRecog){try{window._pauseRecog.stop();}catch(e){}window._pauseRecog=null;}

      if (!hadText) {
        // Rien affiché à l'écran → active le bouton pause, bloque l'app
        setWord("⏸");
        document.body.style.background="var(--bg)";
        stopped = true;
        G("btn-listen-start").disabled = false;
        G("btn-listen-start").textContent = "▶";
        window._pauseSilencePending = false;
        return;
      }

      setTimeout(() => {
        const el = G("current-word");
        el.innerHTML = ""; el.style.fontSize = ""; el.style.color = "";
        el.textContent = "—";
        document.body.style.background="var(--bg)";
        window._pauseSilencePending=false;
        tick();
      }, 2200);
    }, pauseDur * 0.99);
    } // end afterVersePlay
  });
}


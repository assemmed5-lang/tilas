          }, 400);
        }
        if (phase === "exam_fractioned" && !revMode) {
          window._recogActive = false;
          if (recog) { try { recog.stop(); } catch(e) {} recog = null; }
          const SRPlugin = window.Capacitor?.Plugins?.SpeechRecognition;
          if (SRPlugin) {
            try { SRPlugin.stop(); } catch(e) {}
            if (window._srListener) { try { window._srListener.remove(); } catch(e){} window._srListener = null; }
          }
          G("mic-ring").classList.remove("on");
          finalTx = ""; lastFullTx = "";
          setTimeout(() => {
            if (phase === "exam_fractioned" && !revMode) playFracGroupPrompt();
          }, 400);
        }
      }, 300);
    }
  });
});
</script>

window._revExamMode = null;
// Override evaluate to intercept review mode
function evaluate() {
  const heard = norm(finalTx);
  if (revMode && window._revExamMode === "single") {
    revEvaluateSingle(); return;
  }
  if (revMode && window._revExamMode === "all") {
    revEvaluateAll(); return;
  }
  // ── Original evaluate logic ──
  const grid = G("word-grid"); grid.innerHTML = "";
  const from = examSolo ? curVerseIdx : 0;
  const to   = curVerseIdx;
  const allWords = [];
  const verseResults = [];

  if (examSolo) {
    // Exam solo : évaluation mot par mot sur le verset unique
    const words = verses[curVerseIdx].split(/\s+/).filter(Boolean);
    const heardWordsArr = heard.split(/\s+/).filter(Boolean);
    const alignment = alignWords(words, heardWordsArr);
    words.forEach((w, i) => {
      allWords.push({ w, ok: alignment[i], vi: curVerseIdx });
    });
    const versePct = Math.round(allWords.filter(x=>x.ok).length / allWords.length * 100);
    verseResults.push({ vi: curVerseIdx, passed: versePct >= 70, pct: versePct });
  } else {
    // Exam collectif : on aligne TOUTE la plage de mots attendus (tous
    // versets confondus) en une seule passe, pour que l'ordre global de la
    // récitation soit respecté à travers les frontières de versets — puis
    // on répartit les résultats verset par verset pour le calcul du score.
    const heardWordsArr = heard.split(/\s+/).filter(Boolean);
    const allExpectedWords = [];
    for (let vi = from; vi <= to; vi++) {
      const words = verses[vi].split(/\s+/).filter(Boolean);
      words.forEach(w => { allExpectedWords.push(w); });
    }
    const globalAlignment = alignWords(allExpectedWords, heardWordsArr);
    let gi = 0;
    for (let vi = from; vi <= to; vi++) {
      const words = verses[vi].split(/\s+/).filter(Boolean);
      const verseWords = [];
      words.forEach(w => {
        const ok = globalAlignment[gi]; gi++;
        verseWords.push({ w, ok, vi });
        allWords.push({ w, ok, vi });
      });
      const versePct = Math.round(verseWords.filter(x=>x.ok).length / verseWords.length * 100);
      verseResults.push({ vi, passed: versePct >= 70, pct: versePct });
    }
  }

  // Toujours afficher le verset avec mots ratés en rouge dans #current-word
  const displayVerseIndices = [];
  for (let vi = from; vi <= to; vi++) displayVerseIndices.push(vi);
  showVerseWithMisses(displayVerseIndices, heard);

  // Score = % de versets qui passent (pas % de mots global) — gardé pour l'affichage
  const passedVerses = verseResults.filter(r => r.passed).length;
  const score = Math.round((passedVerses / verseResults.length) * 100);
  const box = G("score-box"); box.className = "score-box";
  const nm  = G("n-missing"), nx = G("n-extra");
  nm.classList.add("hidden"); nx.classList.add("hidden");

  // ── Taux d'échec global au niveau MOT (toutes les mots examinés, tous versets confondus) ──
  const totalWordsCount  = allWords.length;
  const failedWordsCount = allWords.filter(x => !x.ok).length;
  const failRatio = totalWordsCount ? (failedWordsCount / totalWordsCount) : 0;

  if (score >= 70) {
    setTimeout(() => {
      setWord("—");
      advanceAfterPass();
    }, 2800);
  } else if (failRatio < 0.5) {
    // Moins de 50% de mots ratés → quiz vocal fractionné ciblé sur les mots ratés
    setTimeout(() => {
      setWord("—");
      beginFractionedQuiz(allWords, advanceAfterPass);
    }, 1500);
  } else {
    // 50% ou plus de mots ratés → réexamen complet classique
    setTimeout(() => {
      setWord("—");
      const allIndices = [];
      const from2 = examSolo ? curVerseIdx : 0;
      for (let i = from2; i <= curVerseIdx; i++) allIndices.push(i);
      beginRetryListenPhase(allIndices);
    }, 3500);
  }
}

/* ══════════════════════════════════════════════
   QUIZ VOCAL FRACTIONNÉ (déclenché si < 50% de mots ratés)
   Au lieu de rejouer tout le verset, on cible uniquement les
   mots ratés, groupés par consécutivité, et on demande à
   l'utilisateur de répéter chaque groupe après avoir entendu
   le passage qui le précède immédiatement.
   ══════════════════════════════════════════════ */

// Regroupe les mots ratés consécutifs (même verset, indices contigus)
function groupConsecutiveFails(allWords) {
  // allWords est déjà dans l'ordre verset/mot (boucles for/forEach séquentielles)
  const groups = [];
  let cur = null;
  allWords.forEach((item, globalIdx) => {
    if (!item.ok) {
      if (cur && cur.vi === item.vi && globalIdx === cur._lastGlobalIdx + 1) {
        cur.words.push(item.w);
        cur._lastGlobalIdx = globalIdx;
      } else {
        if (cur) groups.push(cur);
        cur = { vi: item.vi, words: [item.w], _lastGlobalIdx: globalIdx, _firstGlobalIdx: globalIdx };
      }
    } else {
      if (cur) { groups.push(cur); cur = null; }
    }
  });
  if (cur) groups.push(cur);
  return groups;
}

// Phrase arabe demandant de répéter N mots (ou la suite de l'aya entière)
function arabicRepeatPhrase(n, isFullRest) {
  if (isFullRest) return "أعد من فضلك الآية التي تلي";
  if (n === 1) return "أعد من فضلك الكلمة التي تلي";
  if (n === 2) return "أعد من فضلك الكلمتين التي تليان";
  if (n === 3) return "أعد من فضلك الكلمات الثلاث التي تلي";
  if (n === 4) return "أعد من فضلك الكلمات الأربع التي تلي";
  return "أعد من فضلك الكلمات التي تلي";
}

// ── Synthèse vocale (TTS) : fait DIRE le texte en arabe par l'app,
// en plus de l'affichage textuel. Utilise l'API navigateur native
// speechSynthesis (gratuite, voix arabe fournie par le système/Android),
// cohérente avec ar-SA déjà utilisé pour la reconnaissance vocale.
function speakArabic(text, onEnd) {
  if (!('speechSynthesis' in window) || !text) {
    if (onEnd) onEnd();
    return;
  }
  try {
    window.speechSynthesis.cancel(); // annule toute lecture en attente
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = "ar-SA";
    utter.rate = 0.95;
    let done = false;
    function finish() {
      if (done) return;
      done = true;
      if (onEnd) onEnd();
    }
    utter.onend = finish;
    utter.onerror = finish;
    // Filet de sécurité : si l'event onend ne se déclenche jamais
    // (cas connu sur certains WebView Android), on continue quand même.
    setTimeout(finish, 6000);
    window.speechSynthesis.speak(utter);
  } catch (e) {
    if (onEnd) onEnd();
  }
}

// Trouve, pour un groupe de mots ratés du verset vi, la fenêtre audio
// du passage qui PRÉCÈDE ce groupe (pour faire écouter l'élan avant répétition).
// On s'appuie sur wordCues (mêmes timings que ceux affichés mot à mot).
function getPrecedingAudioWindow(vi, groupWordsCountFromStart) {
  const vc = verseCues[vi];
  if (!vc) return null;
  const versetWords = wordCues.filter(c => c.start >= vc.start - 0.05 && c.start < vc.end);
  if (!versetWords.length) return { start: vc.start, end: vc.start };
  // groupWordsCountFromStart = index (0-based) du premier mot du groupe dans le verset
  const idx = Math.max(0, Math.min(groupWordsCountFromStart, versetWords.length));
  const endCue = versetWords[idx - 1];
  return { start: vc.start, end: endCue ? endCue.end : vc.start };
}

function beginFractionedQuiz(allWords, onAllDone) {
  const groups = groupConsecutiveFails(allWords);
  if (!groups.length) { onAllDone(); return; }

  // Calculer, pour chaque groupe, l'index (0-based) du premier mot du groupe DANS SON VERSET
  // (nécessaire pour retrouver le passage qui précède via wordCues).
  const wordIdxInVerse = {}; // vi -> compteur courant
  allWords.forEach(item => {
    if (wordIdxInVerse[item.vi] === undefined) wordIdxInVerse[item.vi] = -1;
    wordIdxInVerse[item.vi]++;
    item._idxInVerse = wordIdxInVerse[item.vi];
  });
  groups.forEach(g => {
    const firstItem = allWords[g._firstGlobalIdx];
    g.startIdxInVerse = firstItem._idxInVerse;
  });

  fracGroups = groups;
  fracGroupIdx = 0;
  fracOnDone = onAllDone;
  phase = "exam_fractioned";
  playFracGroupPrompt();
}

function playFracGroupPrompt() {
  if (fracGroupIdx >= fracGroups.length) {
    phase = "exam";
    fracGroups = []; fracGroupIdx = 0;
    const done = fracOnDone; fracOnDone = null;
    if (done) done();
    return;
  }
  const g = fracGroups[fracGroupIdx];
  const vc = verseCues[g.vi];
  const verseWordsTotal = (verses[g.vi] || "").split(/\s+/).filter(Boolean).length;
  const isFullRest = (g.startIdxInVerse + g.words.length) >= verseWordsTotal && g.words.length > 4;

  finalTx = ""; lastFullTx = "";
  G("card-listen").classList.add("hidden");
  G("card-recite").classList.remove("hidden");
  G("card-result").classList.add("hidden");
  G("exam-ayahs-box").classList.add("hidden");
  G("phase-label-recite").textContent = "تصحيح مُركَّز — الآية " + (g.vi + 1);
  const promptPhrase = arabicRepeatPhrase(g.words.length, isFullRest);
  G("rec-hint").textContent = promptPhrase;
  G("rec-status").textContent = "...";
  G("transcript").style.display = "none";
  G("mic-ring").classList.remove("on");
  G("btn-rec-start").classList.add("hidden");
  G("btn-rec-stop").classList.add("hidden");
  G("card-recite").scrollIntoView({ behavior:"smooth", block:"start" });

  // Jouer le passage qui précède le groupe, comme élan avant répétition
  const win = getPrecedingAudioWindow(g.vi, g.startIdxInVerse);
  const p = G("audio-player");
  function startMicForGroup() {
    G("rec-status").textContent = "اضغط الزر وكرر ما طُلب";
    G("btn-rec-start").classList.remove("hidden");
  }
  function playPrecedingPassage() {
    G("rec-status").textContent = "استمع أولاً...";
    if (!win || win.end <= win.start + 0.05 || !audioUrl) {
      startMicForGroup();
      return;
    }
    window._activeWindow = { start: win.start, end: win.end };
    window._activeCues = [];
    playing = true; stopped = false;
    if (p._loadedUrl !== audioUrl) { p.src = audioUrl; p._loadedUrl = audioUrl; p.load(); }
    playOnce(() => { startMicForGroup(); });
  }
  // On DIT la phrase d'abord (en plus de l'afficher), puis on joue le
  // passage audio précédent, puis on active le micro.
  speakArabic(promptPhrase, playPrecedingPassage);
}

// Appelée par btn-rec-stop quand phase === "exam_fractioned" (voir hook plus bas)
function evaluateFracGroup() {
  const heard = norm(finalTx);
  const g = fracGroups[fracGroupIdx];
  if (!g) { playFracGroupPrompt(); return; }
  const heardWordsArr = heard.split(/\s+/).filter(Boolean);
  const results = alignWords(g.words, heardWordsArr);
  const allOk = results.every(Boolean);
  showVerseWithMisses([g.vi], heard);
  G("rec-status").textContent = allOk ? "✅ صحيح، أحسنت!" : "❌ أعد المحاولة";
  setTimeout(() => {
    setWord("—");
    if (allOk) {
      fracGroupIdx++;
    }
    // Si échec : on relance le MÊME groupe (même question, même passage précédent)
    playFracGroupPrompt();
  }, allOk ? 1400 : 1800);
}

/* ── startNormalSession : lance la session habituelle d'apprentissage ── */
function startNormalSession() {
  revMode = false;
  window._revExamMode = null;
  G("review-phase-label").style.display = "none";

  // Vérifier si des révisions bloquent les nouvelles sourates
  const due = getDueReviews();
  if (due.length > 0) {
    // Des révisions dues → ne pas avancer, proposer la révision
    checkAndProposeRevision();
    return;
  }

  startSession();
}


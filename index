/* ══════════════════════════════════════════════
   SPEECH RECOGNITION — EXAM PHASE
   Stratégie : webkitSpeechRecognition EN PRIORITÉ.
   Elle fonctionne dans Chrome (PC) ET dans la WebView
   Capacitor grâce à androidScheme:'https' (origine sécurisée).
   Le plugin natif Capacitor n'est utilisé qu'en dernier recours.
   ══════════════════════════════════════════════ */
async function startRecog() {
  finalTx = ""; lastFullTx = "";

  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;

  if (SR) {
    function makeRecog() {
      const r = new SR();
      r.lang = "ar-SA";
      r.continuous = true;
      r.interimResults = true;
      r.maxAlternatives = 3;
      r.onstart = () => { G("mic-ring").classList.add("on"); };
      r.onresult = e => {
        let interim = "";
        for (let i = e.resultIndex; i < e.results.length; i++) {
          if (e.results[i].isFinal) finalTx += e.results[i][0].transcript + " ";
          else interim += e.results[i][0].transcript;
        }
        const candidate = (finalTx + interim).trim();
        if (candidate.length >= lastFullTx.length) lastFullTx = candidate;
        G("transcript").textContent = lastFullTx || "...";
        setWord(lastFullTx.trim().split(/\s+/).filter(Boolean).slice(-1)[0] || "—");
      };
      r.onerror = e => {
        if (e.error !== "aborted") G("rec-status").textContent = "خطأ: " + e.error;
      };
      r.onend = restartRecog;
      return r;
    }

    function restartRecog() {
      G("mic-ring").classList.remove("on");
      // CRITIQUE : à la coupure, des mots "interim" (pas encore isFinal)
      // peuvent être perdus et ne jamais rejoindre finalTx, alors qu'ils
      // étaient déjà visibles à l'écran via lastFullTx (finalTx + interim).
      // On fige donc TOUJOURS finalTx sur lastFullTx ici, qui est le texte
      // le plus complet connu à cet instant — jamais l'inverse.
      if (lastFullTx.trim().length >= finalTx.trim().length) {
        finalTx = lastFullTx.trim() + " ";
      }
      if (!window._recogActive) return;
      // Redémarrage immédiat (sans setTimeout) pour minimiser le trou
      // d'écoute pendant lequel des mots récités seraient totalement perdus.
      try {
        recog = makeRecog();
        recog.start();
      } catch(e) {
        // InvalidStateError possible si l'ancien moteur n'a pas fini de
        // se libérer : on retente une fois après un court délai.
        setTimeout(() => {
          if (!window._recogActive) return;
          try { recog = makeRecog(); recog.start(); } catch(e2) {}
        }, 80);
      }
    }

    recog = makeRecog();
    recog.onstart = () => {
      G("mic-ring").classList.add("on");
      G("rec-status").textContent = "جارٍ الاستماع... تكلّم الآن!";
      const t = G("transcript"); t.style.display = "block"; t.textContent = "...";
      setWord("—");
    };

    try {
      window._recogActive = true;
      recog.start();
      // Filet de sécurité : toutes les 500ms, on garantit que finalTx ne
      // soit jamais en retard sur lastFullTx (ce qui est affiché à l'écran),
      // peu importe la séquence exacte d'événements Web Speech reçus.
      if (window._recogWatchdog) clearInterval(window._recogWatchdog);
      window._recogWatchdog = setInterval(() => {
        if (!window._recogActive) { clearInterval(window._recogWatchdog); return; }
        if (lastFullTx.trim().length > finalTx.trim().length) {
          finalTx = lastFullTx.trim() + " ";
        }
      }, 500);
    } catch(e) {
      G("rec-status").textContent = "لا يمكن بدء التعرف الصوتي: " + e.message;
      G("btn-rec-stop").classList.add("hidden");
      G("btn-rec-start").classList.remove("hidden");
    }

  } else {
    const SRPlugin = window.Capacitor?.Plugins?.SpeechRecognition;
    if (!SRPlugin) {
      G("rec-status").textContent = "التعرف الصوتي غير مدعوم على هذا الجهاز.";
      G("btn-rec-stop").classList.add("hidden");
      G("btn-rec-start").classList.remove("hidden");
      return;
    }

    try { await SRPlugin.requestPermission(); } catch(e) {}
    if (window._srListener) { try { window._srListener.remove(); } catch(e){} window._srListener = null; }

    G("mic-ring").classList.add("on");
    G("rec-status").textContent = "جارٍ الاستماع... تكلّم الآن!";
    G("transcript").style.display = "block";
    G("transcript").textContent = "...";
    setWord("—");

    try {
      window._srListener = await SRPlugin.addListener("partialResults", data => {
        const txt = (data.matches && data.matches[0]) ? data.matches[0] : "";
        if (txt.length >= lastFullTx.length) { lastFullTx = txt; finalTx = txt; }
        G("transcript").textContent = lastFullTx || "...";
        G("transcript").style.display = "block";
        setWord(lastFullTx.trim().split(/\s+/).filter(Boolean).slice(-1)[0] || "—");
      });
      await SRPlugin.start({ language: "ar-SA", partialResults: true, popup: false });
    } catch(e) {
      G("rec-status").textContent = "خطأ في بدء التعرف: " + (e.message || e);
      G("mic-ring").classList.remove("on");
      G("btn-rec-stop").classList.add("hidden");
      G("btn-rec-start").classList.remove("hidden");
    }
  }
}

G("btn-rec-start").addEventListener("click", () => {
  G("btn-rec-start").classList.add("hidden");

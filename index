function parseSRT(txt) {
  const cues = [];
  const toSec = (h,mn,s) => +h*3600 + +mn*60 + parseFloat(s.replace(",","."));
  txt = txt.replace(/^\uFEFF/,"").replace(/\r\n/g,"\n").replace(/\r/g,"\n").trim();
  const lines = txt.split("\n").map(l => l.trim()).filter(l => l !== "");
  const timingRe = /(\d+):(\d+):(\d+[,\.]\d+)\s*-->\s*(\d+):(\d+):(\d+[,\.]\d+)/;
  const seqRe = /^\d+$/;
  let i = 0;
  while (i < lines.length) {
    if (seqRe.test(lines[i]) && i+1 < lines.length && timingRe.test(lines[i+1])) i++;
    const m = lines[i] && lines[i].match(timingRe);
    if (!m) { i++; continue; }
    i++;
    const textLines = [];
    while (i < lines.length) {
      if (seqRe.test(lines[i]) && i+1 < lines.length && timingRe.test(lines[i+1])) break;
      if (timingRe.test(lines[i])) break;
      textLines.push(lines[i]);
      i++;
    }
    const text = textLines.join(" ").trim();
    if (!text) continue;
    const start = toSec(m[1],m[2],m[3]);
    const end   = toSec(m[4],m[5],m[6]);
    if (end <= start) continue;
    cues.push({ start, end, text });
  }
  return cues;
}

function norm(s) {
  return s
    .replace(/[\u064B-\u065F\u0670\u0671]/g,"")
    .replace(/[أإآٱا]/g,"ا").replace(/[ىي]/g,"ي").replace(/ة/g,"ه")
    .replace(/ـ/g,"")
    .replace(/(.)\1{2,}/g,"$1$1")
    .replace(/\s+/g," ").trim().toLowerCase();
}

// Deux mots normalisés sont considérés "identiques" avec la même tolérance
// de préfixe utilisée historiquement dans l'app (fautes de reconnaissance/troncature).
function wordsMatch(nw, hw) {
  return hw === nw || (nw.length > 4 && (hw.startsWith(nw.slice(0,4)) || nw.startsWith(hw.slice(0,4))));
}

// ══════════════════════════════════════════════
// alignWords : alignement GLOUTON gauche-à-droite entre les mots ATTENDUS
// (verset) et les mots ENTENDUS (transcription).
//
// Principe : on parcourt les mots attendus DANS L'ORDRE (1, 2, 3...). Pour
// chaque mot attendu, on cherche le PREMIER mot entendu disponible (non
// encore utilisé) situé strictement APRÈS la position du dernier mot
// entendu déjà validé. Si trouvé → validé et "consommé" (ne peut plus
// servir à un autre mot attendu). Si non trouvé → raté.
//
// Pourquoi cet algorithme et pas un simple "le mot existe dans heard" :
// - DUPLICATAS : si le verset répète un mot (ex: كَيْفَ deux fois) et que
//   l'utilisateur ne le dit qu'une fois, un seul des deux est validé —
//   jamais les deux à partir d'une seule occurrence entendue.
// - ORDRE : si l'utilisateur dit "رب العالمين" avant "الحمد لله" (alors que
//   le verset attend l'inverse), رب/العالمين ne sont PAS validés tant que
//   leurs prédécesseurs (الحمد/لله) n'ont pas été dits avant eux dans
//   l'enregistrement. En revanche, si l'utilisateur a commencé à parler
//   avant l'activation du micro et que رب/العالمين sont captés en premier,
//   puis qu'il dit ensuite الحمد/لله dans le bon ordre relatif entre eux,
//   ces deux derniers SONT validés (ils respectent l'ordre l'un par rapport
//   à l'autre) — seuls رب/العالمين restent non validés et donc à refaire.
//
// Retourne un tableau de booléens, un par mot attendu (true = validé).
// ══════════════════════════════════════════════
function alignWords(expectedWords, heardWordsArr) {
  const n = expectedWords.length;
  const nExp = expectedWords.map(norm);
  const nHeard = heardWordsArr.map(norm);
  const used = new Array(nHeard.length).fill(false);
  const ok = new Array(n).fill(false);
  let lastUsedPos = -1;
  for (let i = 0; i < n; i++) {
    let found = -1;
    for (let j = lastUsedPos + 1; j < nHeard.length; j++) {
      if (!used[j] && wordsMatch(nExp[i], nHeard[j])) { found = j; break; }
    }
    if (found !== -1) {
      ok[i] = true;
      used[found] = true;
      lastUsedPos = found;
    }
  }
  return ok;
}

function findVerseWindow(allCues, verseText) {
  if (!allCues.length || !verseText) return null;
  const nv = norm(verseText);
  const nvWords = nv.split(/\s+/).filter(Boolean);
  if (!nvWords.length) return null;
  const wordList = [];
  allCues.forEach(cue => {
    const ws = cue.text.split(/\s+/).filter(Boolean);
    ws.forEach((w, i) => {
      const dur = (cue.end - cue.start) / ws.length;
      wordList.push({ word: norm(w), start: cue.start + i * dur, end: cue.start + (i+1) * dur });
    });
  });
  let bestStart = -1, bestEnd = -1, bestScore = 0;
  for (let i = 0; i <= wordList.length - nvWords.length; i++) {
    let score = 0;
    for (let j = 0; j < nvWords.length; j++) {
      if (wordList[i+j] && wordList[i+j].word === nvWords[j]) score++;
    }
    const ratio = score / nvWords.length;
    if (ratio > bestScore) {
      bestScore = ratio;
      bestStart = wordList[i].start;
      bestEnd   = wordList[i + nvWords.length - 1].end;
    }
    if (bestScore === 1) break;
  }
  if (bestScore < 0.4) return null;
  return { start: bestStart, end: bestEnd, score: bestScore };
}

function findVerseCues(allCues, verseText) {
  if (!allCues.length || !verseText) return [];
  const nv = norm(verseText);
  const nvWords = nv.split(/\s+/).filter(Boolean);
  if (!nvWords.length) return [];
  const wordList = [];
  allCues.forEach(cue => {
    const ws = cue.text.split(/\s+/).filter(Boolean);
    ws.forEach((w, i) => {
      const dur = (cue.end - cue.start) / ws.length;
      wordList.push({ word: norm(w), text: w, start: cue.start + i * dur, end: cue.start + (i+1) * dur });
    });
  });
  let bestIdx = 0, bestScore = 0;
  for (let i = 0; i <= wordList.length - nvWords.length; i++) {
    let score = 0;
    for (let j = 0; j < nvWords.length; j++) {
      if (wordList[i+j] && wordList[i+j].word === nvWords[j]) score++;
    }
    if (score > bestScore) { bestScore = score; bestIdx = i; }
    if (bestScore === nvWords.length) break;
  }
  return wordList.slice(bestIdx, bestIdx + nvWords.length);
}


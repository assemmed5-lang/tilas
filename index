function adjustWordSize(el) {
  const txt = el.textContent || "";
  // Enlever diacritiques pour compter les vraies lettres
  const letters = txt.replace(/[ؐ-ًؚ-ٰٟ]/g, "").length;
  let size;
  if      (letters <= 3)  size = "28vw";
  else if (letters <= 5)  size = "22vw";
  else if (letters <= 7)  size = "17vw";
  else if (letters <= 10) size = "13vw";

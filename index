      } catch(e) {
        curSuraIdx = 0;
        chargerSourate(curSuraIdx);
      }
      localStorage.setItem(kidKey("sura"), curSuraIdx);
    } else {
      // Même sourate mais s'assurer que audioUrl est synchronisé
      audioUrl = BANQUE_SOURATES[curSuraIdx].mp3;
    }
  }
  return true;
}


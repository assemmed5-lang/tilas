  G("card-recite").classList.add("hidden");
  G("card-result").classList.add("hidden");
  buildProgressTrack();
  G("bar-surah-wrap").style.display = "none"; // cachée sur kid-select
  if (loadState()) {
    updateBarSurah(); // visible dès le début de la session
    if (phase === "listen" || phase === "retry_listen") beginListenPhase(true); // reprise — garder repCur
    else if (phase === "exam" || phase === "exam_fractioned") {
      // Reprise après interruption en cours d'exam :
      // L'enfant a pu oublier le(s) verset(s) depuis la dernière session.
      // On ne relance JAMAIS l'examen directement : on impose d'abord une
      // ré-écoute (comme après un échec d'examen), puis l'examen reprendra
      // normalement via le flux habituel retry_listen → exam.
      finalTx = ""; lastFullTx = "";
      revMode = false; window._revExamMode = null;
      window._recogActive = false;
      if (recog) { try { recog.stop(); } catch(e) {} recog = null; }
      const allIndices = [];
      const from2 = examSolo ? curVerseIdx : 0;
      for (let i = from2; i <= curVerseIdx; i++) allIndices.push(i);
      beginRetryListenPhase(allIndices);
    }
    else { curVerseIdx=0; examUpTo=0; phase="idle"; retryMissing=[]; repCur=0; repTotal=10; beginListenPhase(); }
  } else {
    curVerseIdx=0; examUpTo=0; phase="idle"; retryMissing=[]; repCur=0; repTotal=10;
    beginListenPhase();
  }
}


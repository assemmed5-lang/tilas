function playGroupOnce(then) {
  const indices = [];
  for (let i = 0; i <= curVerseIdx; i++) indices.push(i);
  function playNext() {
    if (!indices.length) { G("audio-player").playbackRate = 1.0; then(); return; }
    const vi = indices.shift();
    const vc = verseCues[vi];
    if (!vc) { playNext(); return; }
    window._activeWindow = { start: vc.start, end: vc.end };
    window._activeCues = wordCues.filter(c => c.start >= vc.start - 0.05 && c.start < vc.end);
    G("audio-player").playbackRate = 1.0;
    playOnce(playNext);
  }
  playNext();
}

function advanceAfterPass() {
  updateBarSurah();
  if (examSolo) {
    if (curVerseIdx === 0) {
      const next = curVerseIdx + 1;

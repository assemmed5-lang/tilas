function requestPermissionAndStart() {
  // Démarrer l'app immédiatement, demander le micro en arrière-plan
  checkRevisionOrStart();
  // Demande de permission micro en arrière-plan (ne bloque pas le démarrage)
  try {
    if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
      navigator.mediaDevices.getUserMedia({ audio: true })
        .then(stream => { stream.getTracks().forEach(t => t.stop()); })
        .catch(() => {});
    }
  } catch(e) {}
}

function checkRevisionOrStart() {
  // Proposer une révision si due, sinon lancer la session normale
  if (!checkAndProposeRevision()) {
    startSession();
  }
}


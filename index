function applyStateObj(s) {
  if (!s || s.phase === "idle") return false;
  curVerseIdx = s.curVerseIdx || 0;
  phase       = s.phase || "idle";
  repCur      = s.repCur || 0;
  repTotal    = s.repTotal || 10;
  examSolo    = s.examSolo || false;
  examUpTo    = s.examUpTo || 0;
  if (typeof s.curSuraIdx === "number" && s.curSuraIdx >= 0 && s.curSuraIdx < BANQUE_SOURATES.length) {
    if (s.curSuraIdx !== curSuraIdx) {
      curSuraIdx = s.curSuraIdx;
      try {

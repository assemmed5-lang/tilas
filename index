function updateBarSurah() {
  const wrap = G("bar-surah-wrap");
  if (!wrap) return;
  if (!verses || !verses.length) { wrap.style.display = "none"; return; }
  const totalWords = wordCues.length || verses.join(" ").split(/\s+/).filter(Boolean).length;
  // Mots appris = mots des versets déjà passés (curVerseIdx versets complétés)
  let learnedWords = 0;
  for (let i = 0; i < curVerseIdx; i++) {
    if (verses[i]) learnedWords += verses[i].split(/\s+/).filter(Boolean).length;
  }
  const pct = totalWords ? Math.round((learnedWords / totalWords) * 100) : 0;
  G("bar-surah-fill").style.width = pct + "%";
  wrap.style.display = "block";
}


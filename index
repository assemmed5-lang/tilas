/* ══════════════════════════════════════════════
   SESSION DE RÉVISION D'UNE SOURATE COMPLÈTE
   ══════════════════════════════════════════════
   Étapes :
   1. Écoute de chaque verset (1 fois) successivement
   2. Examen verset par verset → si échec, répéter ce verset, puis re-examiner
   3. Lecture complète de la sourate (1 fois)
   4. Examen de la sourate entière → si échec, répéter, puis re-examiner
   5. Succès → marquer révision faite → retour normal
*/

let revMode = false;       // on est en mode révision
let revSuraIdx = -1;       // sourate en cours de révision
let revVerseIdx = 0;       // verset courant (phase écoute/examen individuel)
let revPhase = "listen";   // "listen" | "exam_single" | "play_all" | "exam_all"
let revVerses = [];        // versets de la sourate en révision
let revVerseCues = [];
let revWordCues  = [];
let revAudioUrl  = "";

function startReviewSession(suraIdx) {
  revMode = true;
  revSuraIdx = suraIdx;
  revVerseIdx = 0;
  revPhase = "listen";

  const sura = BANQUE_SOURATES[suraIdx];
  revAudioUrl  = sura.mp3;
  revVerseCues = parseSRT(sura.srtVersets);
  revWordCues  = parseSRT(sura.srtMots);
  revVerses    = revVerseCues.map(c => c.text.split(/\n/).filter(l => !/-->/.test(l) && !/^\d+$/.test(l.trim())).join(" ").trim());

  // Charger l'audio pour la révision
  const p = G("audio-player");
  p.src = revAudioUrl; p._loadedUrl = revAudioUrl; p.load();

  showRevPhaseLabel("مراجعة " + sura.nom + " — استمع للآيات");

  // Afficher les cards
  G("card-listen").classList.remove("hidden");
  G("card-recite").classList.add("hidden");
  G("card-result").classList.add("hidden");
  buildRevProgressTrack();

  revListenCurrentVerse();
}

function showRevPhaseLabel(txt) {
  const el = G("review-phase-label");
  el.textContent = txt;
  el.style.display = "block";
}

function buildRevProgressTrack() {
  const track = G("progress-track"); track.innerHTML = "";
  revVerses.forEach((_, i) => {
    const d = document.createElement("div");
    d.className = "pt-step"; d.id = "pt-" + i;
    track.appendChild(d);
  });
}

/* ── Phase 1 : écoute successive de chaque verset (1 fois) ── */
function revListenCurrentVerse() {
  revPhase = "listen";
  const vc = revVerseCues[revVerseIdx];
  if (!vc) { revVerseIdx++; if (revVerseIdx < revVerses.length) revListenCurrentVerse(); else revStartExamSingle(0); return; }

  window._activeWindow = { start: vc.start, end: vc.end };
  window._activeCues   = revWordCues.filter(c => c.start >= vc.start - 0.05 && c.start < vc.end);

  G("phase-label").textContent = "مراجعة — الآية " + (revVerseIdx+1) + " من " + revVerses.length;
  G("ayah-full-text").textContent = revVerses[revVerseIdx];
  G("ayah-full-box").classList.remove("hidden");
  G("rep-cur").textContent = ""; G("rep-of").textContent = ""; G("rep-state").textContent = "جارٍ تشغيل الآية...";
  G("prog-fill").style.width = "0%"; G("prog-pct").textContent = "";

  // Mark current in track
  revVerses.forEach((_, i) => {
    const d = G("pt-" + i);
    if (d) d.className = "pt-step" + (i < revVerseIdx ? " done" : i === revVerseIdx ? " current" : "");
  });

  // Mettre le bouton start en mode "bloqué" pendant l'écoute
  G("btn-listen-start").classList.add("hidden");
  G("btn-listen-stop").classList.add("hidden");

  playing = true; stopped = false;
  const p = G("audio-player");
  if (p._loadedUrl !== revAudioUrl) { p.src = revAudioUrl; p._loadedUrl = revAudioUrl; p.load(); }
  playOnce(() => {
    revVerseIdx++;
    if (revVerseIdx < revVerses.length) {
      setTimeout(revListenCurrentVerse, 600);
    } else {
      // Toutes les écoutes finies → passer à l'examen verset par verset
      setTimeout(() => revStartExamSingle(0), 800);
    }
  });
}

/* ── Phase 2 : examen verset par verset ── */
let revExamVerseIdx = 0;

function revStartExamSingle(vi) {
  revPhase = "exam_single";
  revExamVerseIdx = vi;

  const vc = revVerseCues[vi];
  if (vc) {
    window._activeWindow = { start: vc.start, end: vc.end };
    window._activeCues   = revWordCues.filter(c => c.start >= vc.start - 0.05 && c.start < vc.end);
  }

  showRevPhaseLabel("مراجعة " + BANQUE_SOURATES[revSuraIdx].nom + " — امتحان كل آية");

  // Update track
  revVerses.forEach((_, i) => {
    const d = G("pt-" + i);
    if (d) d.className = "pt-step" + (i < vi ? " done" : i === vi ? " exam" : "");
  });

  finalTx = ""; lastFullTx = "";
  G("phase-label-recite").textContent = "امتحان الآية " + (vi+1);
  G("exam-ayahs-text").textContent = revVerses[vi];
  G("exam-ayahs-box").classList.remove("hidden");
  G("rec-hint").textContent = "قل الآية " + (vi+1) + " بصوت واضح";
  G("btn-rec-start").classList.remove("hidden");
  G("btn-rec-stop").classList.add("hidden");
  G("rec-status").textContent = "اضغط الزر وابدأ في التلاوة";
  G("transcript").style.display = "none";
  G("mic-ring").classList.remove("on");
  G("card-listen").classList.add("hidden");
  G("card-recite").classList.remove("hidden");
  G("card-result").classList.add("hidden");

  // Override btn-rec-stop pour intercepter l'évaluation en mode révision
  window._revExamMode = "single";
}

function revEvaluateSingle() {
  const heard = norm(finalTx);
  const words = revVerses[revExamVerseIdx].split(/\s+/).filter(Boolean);
  const heardWordsArr = heard.split(/\s+/).filter(Boolean);
  const alignment = alignWords(words, heardWordsArr);
  const allWords = words.map((w, i) => ({ w, ok: alignment[i] }));
  const found = allWords.filter(x => x.ok).length;
  const score = Math.round((found / words.length) * 100);

  G("card-recite").classList.add("hidden");
  G("card-result").classList.add("hidden");
  G("card-listen").classList.remove("hidden");
  showVerseWithMisses([revExamVerseIdx], heard);


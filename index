function playOnce(onEnd) {
  const p = G("audio-player");
  if (!audioUrl) {
    alert("⚠️ الرجاء تحميل ملف MP3 وملف SRT أولاً.");
    stopped = true;
    G("btn-listen-start").classList.remove("hidden");
    G("btn-listen-stop").classList.add("hidden");
    return;
  }
  const win = window._activeWindow;
  if (!win || win.end <= win.start + 0.1) { setTimeout(onEnd, 200); return; }
  const startTime = win.start;
  const endTime   = win.end;
  let ended = false;

  function safeEnd() {
    if (ended) return;
    ended = true;
    if (window._wTimer) { clearInterval(window._wTimer); window._wTimer = null; }
    p.onended = null;
    p.oncanplaythrough = null;
    setWord("—");
    G("current-word-label").textContent = "—";
    onEnd();
  }

  function doPlay() {
    if (window._wTimer) { clearInterval(window._wTimer); window._wTimer = null; }
    p.onended = null;
    setWord("—");
    p.currentTime = startTime;
    const activeCues = window._activeCues || [];
    let lastTime = -1;
    let stuckCount = 0;

    function startInterval() {
      window._wTimer = setInterval(() => {
        if (stopped) { p.pause(); safeEnd(); return; }
        const t = p.currentTime;
        if (t === lastTime) {
          stuckCount++;
          if (stuckCount > 15) { p.pause(); safeEnd(); return; }
        } else {
          stuckCount = 0;
          lastTime = t;
        }
        if (t >= endTime) { p.pause(); safeEnd(); return; }
        const cue = activeCues.find(c => t >= c.start && t < c.end);
        if (cue) {
          setWord(cue.text);
          G("current-word-label").textContent = cue.text;
        }
      }, 80);
    }

    if (phase === "listen") {
      // 5 premières répétitions en ralenti (0.75×), le reste à vitesse normale (1.0×)
      p.playbackRate = repCur < 5 ? 0.75 : 1.0;
    } else {
      p.playbackRate = 1.0;
    }
    p.play().then(() => {
      startInterval();
    }).catch(err => {
      console.warn("play() failed:", err);
      safeEnd();
    });
  }

  function loadAndPlay() {
    p._loadedUrl = audioUrl;
    p.src = audioUrl;
    p.onended = null;
    p.onloadedmetadata = null;
    p.oncanplaythrough = null;
    p.load();
    p.oncanplaythrough = function() { p.oncanplaythrough = null; doPlay(); };
    p.onerror = safeEnd;
  }

  if (p.readyState >= 2) {
    doPlay();
  } else if (p._loadedUrl !== audioUrl) {
    loadAndPlay();
  } else {
    p.oncanplaythrough = function() { p.oncanplaythrough = null; doPlay(); };
    p.onerror = safeEnd;
  }
}

